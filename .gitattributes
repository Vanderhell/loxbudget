# Default: normalize line endings in the repo
* text=auto

# Keep source/docs consistent across platforms
*.c   text eol=lf
*.h   text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh  text eol=lf
*.py  text eol=lf
Makefile text eol=lf

# Windows-specific scripts (if added later)
*.ps1 text eol=crlf
